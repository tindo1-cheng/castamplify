    <script>
        (function() {
            // ---------- CALENDAR ----------
            let currentDate = new Date();
            let currentMonth = currentDate.getMonth();
            let currentYear = currentDate.getFullYear();

            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October',
                'November', 'December'
            ];
            const dayNames = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

            // Sample events (assessment deadlines)
            const events = {
                '2026-07-15': ['Quiz: Broiler Production'],
                '2026-07-20': ['Practical: Dairy Milk'],
                '2026-07-25': ['Capstone Submission'],
                '2026-07-28': ['Final Exam']
            };

            function renderCalendar(month, year) {
                const grid = document.getElementById('calendarGrid');
                const title = document.getElementById('calendarTitle');
                title.textContent = `${monthNames[month]} ${year}`;

                const firstDay = new Date(year, month, 1).getDay();
                const daysInMonth = new Date(year, month + 1, 0).getDate();
                const daysInPrevMonth = new Date(year, month, 0).getDate();

                let html = '';
                // Day names
                dayNames.forEach(d => {
                    html += `<div class="day-name">${d}</div>`;
                });

                // Previous month days
                const startOffset = firstDay;
                for (let i = startOffset - 1; i >= 0; i--) {
                    const day = daysInPrevMonth - i;
                    html += `<div class="day other-month">${day}</div>`;
                }

                // Current month days
                const today = new Date();
                for (let i = 1; i <= daysInMonth; i++) {
                    const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(i).padStart(2,'0')}`;
                    const isToday = (year === today.getFullYear() && month === today.getMonth() && i === today.getDate());
                    const hasEvent = events[dateStr] && events[dateStr].length > 0;
                    let classes = 'day';
                    if (isToday) classes += ' today';
                    if (hasEvent) classes += ' has-event';
                    html += `<div class="${classes}" data-date="${dateStr}">${i}</div>`;
                }

                // Next month days
                const totalCells = startOffset + daysInMonth;
                const remainingCells = (7 - (totalCells % 7)) % 7;
                for (let i = 1; i <= remainingCells; i++) {
                    html += `<div class="day other-month">${i}</div>`;
                }

                grid.innerHTML = html;

                // Add click events to days
                grid.querySelectorAll('.day:not(.other-month)').forEach(el => {
                    el.addEventListener('click', function() {
                        const date = this.dataset.date;
                        if (events[date]) {
                            alert(`📅 Events on ${date}:\n${events[date].join('\n')}`);
                        } else {
                            alert(`📅 ${date} - No events scheduled.`);
                        }
                    });
                });
            }

            document.getElementById('prevMonth').addEventListener('click', function() {
                currentMonth--;
                if (currentMonth < 0) { currentMonth = 11;
                    currentYear--; }
                renderCalendar(currentMonth, currentYear);
            });

            document.getElementById('nextMonth').addEventListener('click', function() {
                currentMonth++;
                if (currentMonth > 11) { currentMonth = 0;
                    currentYear++; }
                renderCalendar(currentMonth, currentYear);
            });

            renderCalendar(currentMonth, currentYear);

            // ---------- SEARCH BAR ----------
            const searchInput = document.getElementById('searchInput');
            const searchBtn = document.getElementById('searchBtn');

            function performSearch() {
                const query = searchInput.value.trim().toLowerCase();
                if (!query) { alert('Please enter a search term.'); return; }

                // Search through courses
                const courses = document.querySelectorAll('.course-card h4');
                let found = [];
                courses.forEach(el => {
                    if (el.textContent.toLowerCase().includes(query)) {
                        found.push(el.textContent);
                        el.closest('.course-card').style.border = '2px solid #2d7a3e';
                    } else {
                        el.closest('.course-card').style.border = '';
                    }
                });

                // Search through students
                const students = document.querySelectorAll('.student-card .name');
                students.forEach(el => {
                    if (el.textContent.toLowerCase().includes(query)) {
                        el.closest('.student-card').style.border = '2px solid #2d7a3e';
                    } else {
                        el.closest('.student-card').style.border = '';
                    }
                });

                if (found.length === 0) {
                    alert(`No results found for "${query}". Try a different term.`);
                } else {
                    alert(`✅ Found ${found.length} result(s) for "${query}":\n${found.slice(0,10).join('\n')}${found.length > 10 ? '\n... and more' : ''}`);
                }
            }

            searchBtn.addEventListener('click', performSearch);
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') performSearch();
            });

            // ---------- NEWSLETTER ----------
            document.getElementById('newsletterBtn').addEventListener('click', function() {
                const email = document.getElementById('newsletterEmail').value.trim();
                if (!email || !email.includes('@')) {
                    alert('Please enter a valid email address.');
                    return;
                }
                alert(`✅ Thank you for subscribing! Updates will be sent to ${email}`);
                document.getElementById('newsletterEmail').value = '';
            });

            // ---------- HELP CHAT ----------
            const helpTabBtn = document.getElementById('helpTabBtn');
            const helpChat = document.getElementById('helpChat');
            const closeHelpChat = document.getElementById('closeHelpChat');
            const helpChatInput = document.getElementById('helpChatInput');
            const helpChatSend = document.getElementById('helpChatSend');
            const helpMessages = document.getElementById('helpMessages');

            helpTabBtn.addEventListener('click', function() {
                helpChat.classList.toggle('active');
                if (helpChat.classList.contains('active')) {
                    helpChatInput.focus();
                }
            });

            closeHelpChat.addEventListener('click', function() {
                helpChat.classList.remove('active');
            });

            function sendHelpMessage() {
                const msg = helpChatInput.value.trim();
                if (!msg) return;

                // Add user message
                const userDiv = document.createElement('div');
                userDiv.className = 'msg user';
                userDiv.textContent = msg;
                helpMessages.appendChild(userDiv);

                helpChatInput.value = '';
                helpMessages.scrollTop = helpMessages.scrollHeight;

                // Simulate bot response
                setTimeout(() => {
                    const botDiv = document.createElement('div');
                    botDiv.className = 'msg bot';

                    const lower = msg.toLowerCase();
                    let response = '';
                    if (lower.includes('course') || lower.includes('enroll')) {
                        response =
                        'We have 213 vocational courses. Each costs $15 from start to finish. You can enroll through the Courses page.';
                    } else if (lower.includes('payment') || lower.includes('pay')) {
                        response = 'We accept EcoCash, M-Pesa, MoMo, Visa/Mastercard, Orange Money, Airtel Money, MTN Mobile, and bank transfers.';
                    } else if (lower.includes('help') || lower.includes('support')) {
                        response = 'I\'m here to help! You can ask about courses, enrollment, payments, placements, or anything else about SkillBridge.';
                    } else if (lower.includes('placement')) {
                        response = 'Stage 2 (Placement): You need to document 2+ applications per week, secure a real placement with an agreed wage, and get a satisfactory employer report. No placement = no Stage 3.';
                    } else if (lower.includes('certificate')) {
                        response = 'You receive your certificate after completing Stage 3 Capstone at 60%+. Your profile converts to a Graduate Profile and you appear on the Graduate Jobs Board.';
                    } else {
                        response =
                        'Thanks for your question! I\'m your SkillBridge assistant. I can help with courses, enrollment, payments, placements, certificates, and more. What would you like to know?';
                    }
                    botDiv.textContent = response;
                    helpMessages.appendChild(botDiv);
                    helpMessages.scrollTop = helpMessages.scrollHeight;
                }, 500);
            }

            helpChatSend.addEventListener('click', sendHelpMessage);
            helpChatInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') sendHelpMessage();
            });

            // ---------- STUDENT DATA ----------
            let students = [
                { id: 1, name: 'Thandive M.', course: 'Broiler Production', country: '🇿🇦 SA', progress: 94,
                    status: 'Stage 2', enrolled: '2026-01-15', checkins: ['2026-07-14', '2026-07-12', '2026-07-10',
                        '2026-07-07'
                    ], assessments: [{ type: 'Quiz', score: 85, date: '2026-07-01' }, { type: 'Practical', score: 90,
                        date: '2026-07-08' }] },
                { id: 2, name: 'Kwame A.', course: 'Dairy Milk', country: '🇬🇭 GH', progress: 88, status: 'Placement',
                    enrolled: '2026-01-20', checkins: ['2026-07-14', '2026-07-11', '2026-07-08'], assessments: [{ type: 'Quiz',
                        score: 78, date: '2026-06-28' }] },
                { id: 3, name: 'Fatima H.', course: 'Tomato Production', country: '🇰🇪 KE', progress: 97,
                    status: 'Certification', enrolled: '2025-12-01', checkins: ['2026-07-14', '2026-07-13', '2026-07-11',
                        '2026-07-09'
                    ], assessments: [{ type: 'Capstone', score: 92, date: '2026-07-05' }, { type: 'Written Exam',
                        score: 88, date: '2026-06-30' }] },
                { id: 4, name: 'James O.', course: 'Tilapia', country: '🇳🇬 NG', progress: 45, status: 'Theory',
                    enrolled: '2026-02-10', checkins: ['2026-07-10'], assessments: [{ type: 'Quiz', score: 55,
                        date: '2026-07-02' }] },
                { id: 5, name: 'Maria S.', course: 'Organic Crop', country: '🇲🇿 MZ', progress: 72, status: 'Stage 2',
                    enrolled: '2026-01-05', checkins: ['2026-07-13', '2026-07-09', '2026-07-06'], assessments: [{ type: 'Quiz',
                        score: 75, date: '2026-07-03' }, { type: 'Practical', score: 80, date: '2026-07-10' }] }
            ];

            // ---------- RENDER FUNCTIONS ----------
            function renderStudents() {
                const grid = document.getElementById('studentGrid');
                grid.innerHTML = '';
                students.forEach(s => {
                    const card = document.createElement('div');
                    card.className = 'student-card';
                    const checkinsThisWeek = s.checkins.filter(d => new Date(d) >= new Date(Date.now() - 7 * 24 * 60 *
                        60 * 1000)).length;
                    card.innerHTML = `
                        <div class="header"><span class="name">${s.name}</span><span class="tag">${s.status}</span></div>
                        <div class="course">${s.course} · ${s.country}</div>
                        <div class="progress-section">
                            <div style="display:flex;justify-content:space-between;font-size:13px;"><span>Progress</span><span>${s.progress}%</span></div>
                            <div class="progress-bar"><div class="progress-fill" style="width:${s.progress}%;"></div></div>
                        </div>
                        <div class="checkin-row">
                            <span><i class="fas fa-calendar-check"></i> Check-ins:</span>
                            ${checkinsThisWeek >= 2 ? `<span class="check">✅ ${checkinsThisWeek}/2</span>` : `<span class="miss">⚠️ ${checkinsThisWeek}/2</span>`}
                        </div>
                        <div class="actions">
                            <button onclick="recordCheckin(${s.id})"><i class="fas fa-calendar-plus"></i> Check-in</button>
                            <button onclick="viewAssessments(${s.id})"><i class="fas fa-clipboard-list"></i> Assessments</button>
                        </div>
                    `;
                    grid.appendChild(card);
                });
            }

            window.recordCheckin = function(id) {
                const student = students.find(s => s.id === id);
                if (!student) return;
                const date = new Date().toISOString().split('T')[0];
                student.checkins.push(date);
                student.progress = Math.min(student.progress + 1, 100);
                renderStudents();
                renderProgressTable();
                alert(`✅ Check-in recorded for ${student.name} on ${date}`);
            };

            window.viewAssessments = function(id) {
                const student = students.find(s => s.id === id);
                if (!student) return;
                alert(`📋 Assessments for ${student.name}:\n${student.assessments.map(a => `${a.type}: ${a.score}% (${a.date})`).join('\n') || 'No assessments yet'}`);
            };

            function renderProgressTable() {
                const tbody = document.getElementById('progressTableBody');
                tbody.innerHTML = '';
                students.forEach(s => {
                    const checkinsThisWeek = s.checkins.filter(d => new Date(d) >= new Date(Date.now() - 7 * 24 * 60 *
                        60 * 1000)).length;
                    const onTrack = checkinsThisWeek >= 2;
                    tbody.innerHTML += `
                        <tr>
                            <td><b>${s.name}</b></td><td>${s.course}</td><td>${s.progress}%</td>
                            <td>${s.checkins.length > 0 ? s.checkins[s.checkins.length-1] : 'None'}</td>
                            <td>${checkinsThisWeek}/2 ${onTrack ? '✅' : '⚠️'}</td>
                            <td><span class="tag">${onTrack ? 'On Track' : 'At Risk'}</span></td>
                        </tr>
                    `;
                });
            }

            function renderAssessments() {
                const tbody = document.getElementById('assessmentTableBody');
                tbody.innerHTML = '';
                students.forEach(s => {
                    s.assessments.forEach(a => {
                        tbody.innerHTML += `
                            <tr><td><b>${s.name}</b></td><td>${s.course}</td><td>${a.type}</td><td>${a.date}</td><td>${a.score}%</td><td><span class="tag">${a.score >= 60 ? 'Pass' : 'Needs Review'}</span></td></tr>
                        `;
                    });
                });
                if (tbody.innerHTML === '') {
                    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#4d6682;">No assessments recorded</td></tr>';
                }
            }

            // ---------- PLACEMENTS, GRADUATES, COUNTRIES ----------
            const placements = [
                { student: 'Thandive M.', employer: 'Sunrise Poultry', location: 'Johannesburg, SA', wage: '$450/mo',
                    report: 'Satisfactory' },
                { student: 'Kwame A.', employer: 'Green Pastures Dairy', location: 'Kumasi, GH', wage: '$400/mo',
                    report: 'Pending' }
            ];
            const pt = document.getElementById('placementTableBody');
            placements.forEach(p => {
                pt.innerHTML += `<tr><td><b>${p.student}</b></td><td>${p.employer}</td><td>${p.location}</td><td>${p.wage}</td><td><span class="tag">${p.report}</span></td></tr>`;
            });

            const graduates = [
                { name: 'Fatima H.', course: 'Tomato Production', score: 97, badge: 'Gold', status: 'Employed' },
                { name: 'David M.', course: 'Tractor Operation', score: 85, badge: 'Gold', status: 'Seeking' }
            ];
            const gt = document.getElementById('graduateTableBody');
            graduates.forEach(g => {
                gt.innerHTML += `<tr><td><b>${g.name}</b></td><td>${g.course}</td><td>${g.score}</td><td><span class="tag">${g.badge}</span></td><td>${g.status}</td></tr>`;
            });

            const countryNames = [
                "Algeria", "Angola", "Benin", "Botswana", "Burkina Faso", "Burundi", "Cabo Verde", "Cameroon",
                "Central African Republic", "Chad", "Comoros", "Congo", "Côte d'Ivoire", "Djibouti", "Egypt",
                "Equatorial Guinea", "Eritrea", "Eswatini", "Ethiopia", "Gabon", "Gambia", "Ghana", "Guinea",
                "Guinea-Bissau", "Kenya", "Lesotho", "Liberia", "Libya", "Madagascar", "Malawi", "Mali",
                "Mauritania", "Mauritius", "Morocco", "Mozambique", "Namibia", "Niger", "Nigeria", "Rwanda",
                "Sao Tome & Principe", "Senegal", "Seychelles", "Sierra Leone", "Somalia", "South Africa",
                "South Sudan", "Sudan", "Tanzania", "Togo", "Tunisia", "Uganda", "Zambia", "Zimbabwe"
            ];
            const cg = document.getElementById('countryGrid');
            countryNames.forEach(c => {
                const chip = document.createElement('div');
                chip.className = 'country-chip';
                chip.innerHTML = `<span>🇦🇫</span> ${c}`;
                cg.appendChild(chip);
            });

            // ---------- SIDEBAR NAV ----------
            const navLinks = document.querySelectorAll('#sidebarNav a');
            const pages = {
                dashboard: document.getElementById('page-dashboard'),
                students: document.getElementById('page-students'),
                progress: document.getElementById('page-progress'),
                assessments: document.getElementById('page-assessments'),
                courses: document.getElementById('page-courses'),
                placements: document.getElementById('page-placements'),
                graduates: document.getElementById('page-graduates'),
                countries: document.getElementById('page-countries'),
                qa: document.getElementById('page-qa')
            };
            const pageTitle = document.getElementById('pageTitle');

            function showPage(pageId) {
                Object.keys(pages).forEach(id => pages[id].classList.add('hidden'));
                if (pages[pageId]) pages[pageId].classList.remove('hidden');
                navLinks.forEach(a => a.classList.remove('active'));
                const activeLink = document.querySelector(`#sidebarNav a[data-page="${pageId}"]`);
                if (activeLink) activeLink.classList.add('active');
                const titles = {
                    dashboard: 'Dashboard',
                    students: 'Students',
                    progress: 'Progress Monitoring',
                    assessments: 'Assessments',
                    courses: 'Courses',
                    placements: 'Placements',
                    graduates: 'Graduates',
                    countries: 'Countries (54)',
                    qa: 'Unlimited AI Q&A'
                };
                pageTitle.innerHTML =
                    `<i class="fas fa-${pageId === 'dashboard' ? 'gauge-high' : 'circle'}" style="color:#2d7a3e;"></i> ${titles[pageId] || 'Dashboard'}`;
            }

            navLinks.forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();
                    const page = this.dataset.page;
                    if (page) showPage(page);
                });
            });

            // ---------- COURSES ----------
            const categoryData = {
                'Crop Production': ['Maize Production', 'Wheat Production', 'Rice (Paddy)', 'Soybean Production'],
                'Poultry Production': ['Broiler Production', 'Layer Production', 'Breeder Flock Management',
                    'Hatchery Operations'
                ],
                'Cattle & Dairy': ['Dairy Milk Production', 'Calf Rearing', 'Beef Feedlot Management',
                    'Beef Ranch & Pastoral Systems'
                ],
                'Pig Production': ['Pig Production', 'Breeder & Boar Management', 'Farrowing & Weaner Production'],
                'Aquaculture & Fisheries': ['Tilapia Production', 'Catfish Production', 'Aquaponics Systems'],
                'Vegetable Production': ['Tomato Production', 'Onion Production', 'Cabbage Production'],
                'Sustainable Agriculture': ['Sustainable Farming', 'Conservation Agriculture', 'Agroecology']
            };

            let allCourses = [];
            let courseCategory = {};
            const prefixes = ['', 'Advanced ', 'Professional '];

            Object.entries(categoryData).forEach(([cat, baseNames]) => {
                baseNames.forEach(baseName => {
                    prefixes.forEach(prefix => {
                        const fullName = prefix + baseName;
                        if (!allCourses.includes(fullName)) {
                            allCourses.push(fullName);
                            courseCategory[fullName] = cat;
                        }
                    });
                });
            });

            // Fill to 213
            while (allCourses.length < 213) {
                allCourses.push('Skill ' + (allCourses.length + 1));
                courseCategory['Skill ' + allCourses.length] = 'Sustainable Agriculture';
            }
            allCourses = allCourses.slice(0, 213);

            // ---------- RENDER COURSES ----------
            const grid = document.getElementById('courseGrid');
            const detail = document.getElementById('courseDetail');
            const detailTitle = document.getElementById('detailTitle');
            const detailSubtitle = document.getElementById('detailSubtitle');
            const moduleContainer = document.getElementById('moduleContainer');

            const moduleTopics = ['Introduction & Overview', 'Core Principles & Equipment', 'Practical Application',
                'Advanced Techniques', 'Health & Safety Protocols', 'Quality Control & Standards',
                'Business & Marketing Strategy', 'Case Studies & Analysis', 'Capstone Planning',
                'Final Review & Assessment'
            ];
            const moduleIcons = ['📖', '🔧', '🔬', '⚡', '🛡️', '📊', '💰', '📋', '🎯', '✅'];

            function getCompleteModules(courseName) {
                return moduleTopics.map((t, i) => {
                    const lessons = [];
                    for (let j = 0; j < 2; j++) {
                        const num = i * 3 + j + 1;
                        const type = j === 0 ? 'Theory & Concepts' : 'Practical Application';
                        lessons.push({ text: `Lesson ${num}: ${t} — ${type}`, type: 'lesson' });
                    }
                    lessons.push({ text: `Quiz: ${t} — 10 questions (auto-graded)`, type: 'quiz' });
                    if (i === 8) {
                        lessons.push({ text: '📌 Capstone Project: Outline & Proposal', type: 'assignment' });
                        lessons.push({ text: '📌 Capstone: Research & Data Collection', type: 'assignment' });
                    }
                    if (i === 9) {
                        lessons.push({ text: '📝 Final Exam (60% pass required)', type: 'exam' });
                        lessons.push({ text: '📝 Certificate Application & Review', type: 'exam' });
                    }
                    while (lessons.length < 5) {
                        lessons.push({ text: `Review: ${t} — Key Takeaways`, type: 'review' });
                    }
                    return {
                        title: t,
                        weeks: `${i*2+1}-${i*2+2}`,
                        icon: moduleIcons[i % moduleIcons.length],
                        lessons: lessons
                    };
                });
            }

            function renderCourseDetail(courseName) {
                detail.classList.add('visible');
                detailTitle.textContent = courseName;
                const cat = courseCategory[courseName] || 'Vocational';
                detailSubtitle.textContent = `9 months · 10 modules · 3 stages · $15 · ${cat}`;
                const modules = getCompleteModules(courseName);
                moduleContainer.innerHTML = '';
                modules.forEach((m, i) => {
                    const block = document.createElement('div');
                    block.className = 'module-block';
                    let lessonsHTML = '';
                    m.lessons.forEach(l => {
                        lessonsHTML += `
                            <div class="lesson-item"><span>•</span> ${l.text} <span class="type">${l.type}</span></div>
                        `;
                    });
                    block.innerHTML = `
                        <h4><span>${m.icon} Module ${i+1}: ${m.title}</span> <span class="weeks">Weeks ${m.weeks}</span></h4>
                        ${lessonsHTML}
                    `;
                    moduleContainer.appendChild(block);
                });
                document.getElementById('progressFill').style.width = '100%';
                document.getElementById('progressText').textContent = '100%';
            }

            function renderCourses(category = 'all') {
                let filtered = category === 'all' ? allCourses : allCourses.filter(c => courseCategory[c] === category);
                grid.innerHTML = '';
                filtered.forEach(c => {
                    const card = document.createElement('div');
                    card.className = 'course-card';
                    const cat = courseCategory[c] || 'Vocational';
                    card.innerHTML = `
                        <h4>${c}</h4>
                        <div class="meta"><span>${cat}</span><span>$15</span></div>
                        <div style="font-size:11px; color:#4d6682; margin-top:4px;">10 modules · 9 mo</div>
                    `;
                    card.addEventListener('click', function() {
                        renderCourseDetail(c);
                        detail.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    });
                    grid.appendChild(card);
                });
                document.querySelectorAll('.category-filter button').forEach(btn => {
                    btn.classList.toggle('active', btn.dataset.category === category);
                });
            }

            // Build category filter
            const filterContainer = document.getElementById('categoryFilter');
            filterContainer.innerHTML = '';
            const allBtn = document.createElement('button');
            allBtn.className = 'active';
            allBtn.dataset.category = 'all';
            allBtn.textContent = `All (${allCourses.length})`;
            allBtn.addEventListener('click', () => renderCourses('all'));
            filterContainer.appendChild(allBtn);

            const catKeys = Object.keys(categoryData);
            catKeys.forEach(cat => {
                const btn = document.createElement('button');
                btn.dataset.category = cat;
                const count = allCourses.filter(c => courseCategory[c] === cat).length;
                btn.textContent = `${cat} (${count})`;
                btn.addEventListener('click', () => renderCourses(cat));
                filterContainer.appendChild(btn);
            });

            renderCourses('all');
            if (allCourses.length) renderCourseDetail(allCourses[0]);

            // ---------- AI Q&A ----------
            const qaInput = document.getElementById('qaInput');
            const qaSubmit = document.getElementById('qaSubmit');
            const qaResponse = document.getElementById('qaResponse');

            const knowledgeBase = {
                'female pig': "A female pig is called a GILT before farrowing, and a SOW after.",
                'male pig': "A male pig is called a BOAR. Castrated males are BARROWS.",
                'piglet': "A baby pig is called a PIGLET. The birth process is FARROWING.",
                'placement': "Stage 2: document 2+ applications/week, secure a placement with agreed wage.",
                'capstone': "Work-based project from placement. Pass at 60%+ for certificate.",
                'soil': "Soil Science covers: soil types, nutrient cycling, pH, organic matter, fertilizer.",
                'maize': "Maize Production covers: land preparation, planting, fertilizer, pest control, harvesting.",
                'broiler': "Broiler Production covers: chick management, feeding, vaccination, housing, processing.",
                'dairy': "Dairy Milk covers: herd management, milking, milk quality, processing.",
                'tilapia': "Tilapia covers: pond construction, fingerlings, feeding, water quality, harvesting.",
                'tomato': "Tomato covers: nursery, transplanting, pest control, irrigation, marketing."
            };

            function answerQuestion(q) {
                const lower = q.toLowerCase();
                for (const [key, answer] of Object.entries(knowledgeBase)) {
                    if (lower.includes(key)) return answer;
                }
                if (lower.includes('what is') || lower.includes('define')) {
                    if (lower.includes('gilt') || lower.includes('sow')) return knowledgeBase['female pig'];
                    if (lower.includes('boar')) return knowledgeBase['male pig'];
                    if (lower.includes('piglet')) return knowledgeBase['piglet'];
                }
                if (lower.includes('how to') || lower.includes('how do')) {
                    if (lower.includes('placement')) return knowledgeBase['placement'];
                    if (lower.includes('start')) return "Enrol for $15, access all 10 modules, complete lessons and quizzes, pass at 60%+ to progress.";
                }
                if (lower.includes('cost') || lower.includes('price')) return "Each course is $15 from start to finish.";
                if (lower.includes('certificate')) return knowledgeBase['capstone'];
                return "I'm your AI tutor. I know all 213 courses. Ask about specific courses, placements, grading, or any agricultural topic.";
            }

            qaSubmit.addEventListener('click', function() {
                const q = qaInput.value.trim();
                if (!q) { qaResponse.textContent = 'Please type a question.'; return; }
                qaResponse.textContent = 'Thinking...';
                setTimeout(() => {
                    const answer = answerQuestion(q);
                    qaResponse.textContent = answer;
                }, 300);
            });

            qaInput.addEventListener('keypress', function(e) { if (e.key === 'Enter') qaSubmit.click(); });

            // ---------- ENROLLMENT ----------
            const enrollBtn = document.getElementById('enrollBtn');
            const enrollModal = document.getElementById('enrollModal');
            const enrollModalClose = document.getElementById('enrollModalClose');
            const enrollForm = document.getElementById('enrollForm');

            enrollBtn.addEventListener('click', () => {
                enrollModal.classList.add('active');
                document.body.style.overflow = 'hidden';
                document.getElementById('enrollDate').value = new Date().toISOString().split('T')[0];
            });

            enrollModalClose.addEventListener('click', () => {
                enrollModal.classList.remove('active');
                document.body.style.overflow = '';
            });
            enrollModal.addEventListener('click', (e) => { if (e.target === e.currentTarget) { enrollModal.classList.remove(
                        'active');
                    document.body.style.overflow = ''; } });

            enrollForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const name = document.getElementById('enrollName').value.trim();
                const country = document.getElementById('enrollCountry').value;
                const course = document.getElementById('enrollCourse').value;
                const date = document.getElementById('enrollDate').value;
                if (!name || !country || !course) { alert('Please fill in all required fields.'); return; }
                const newStudent = {
                    id: students.length + 1,
                    name: name,
                    course: course,
                    country: country,
                    progress: 0,
                    status: 'Theory',
                    enrolled: date,
                    checkins: [],
                    assessments: []
                };
                students.push(newStudent);
                renderStudents();
                renderProgressTable();
                renderAssessments();
                alert(`✅ ${name} enrolled successfully! Progress folder created.`);
                enrollForm.reset();
                enrollModal.classList.remove('active');
                document.body.style.overflow = '';
            });

            // ---------- ASSESSMENT ----------
            const addAssessmentBtn = document.getElementById('addAssessmentBtn');
            const assessmentModal = document.getElementById('assessmentModal');
            const assessmentModalClose = document.getElementById('assessmentModalClose');
            const assessmentForm = document.getElementById('assessmentForm');

            addAssessmentBtn.addEventListener('click', () => {
                assessmentModal.classList.add('active');
                document.body.style.overflow = 'hidden';
                document.getElementById('assessmentDate').value = new Date().toISOString().split('T')[0];
            });

            assessmentModalClose.addEventListener('click', () => {
                assessmentModal.classList.remove('active');
                document.body.style.overflow = '';
            });
            assessmentModal.addEventListener('click', (e) => { if (e.target === e.currentTarget) { assessmentModal.classList
                        .remove('active');
                    document.body.style.overflow = ''; } });

            assessmentForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const studentName = document.getElementById('assessmentStudent').value;
                const type = document.getElementById('assessmentType').value;
                const score = parseInt(document.getElementById('assessmentScore').value);
                const date = document.getElementById('assessmentDate').value;
                const student = students.find(s => s.name === studentName);
                if (!student) { alert('Student not found.'); return; }
                student.assessments.push({ type, score, date });
                const avgScore = student.assessments.reduce((sum, a) => sum + a.score, 0) / student.assessments.length;
                student.progress = Math.min(Math.round(avgScore * 0.9 + 10), 100);
                renderStudents();
                renderProgressTable();
                renderAssessments();
                alert(`✅ Assessment recorded for ${studentName}`);
                assessmentForm.reset();
                assessmentModal.classList.remove('active');
                document.body.style.overflow = '';
            });

            // ---------- HELP MODAL ----------
            const helpBtn = document.getElementById('helpBtn');
            const helpModal = document.getElementById('helpModal');
            const modalClose = document.getElementById('modalClose');
            const helpForm = document.getElementById('helpForm');

            helpBtn.addEventListener('click', () => {
                helpModal.classList.add('active');
                document.body.style.overflow = 'hidden';
            });

            function closeHelpModal() {
                helpModal.classList.remove('active');
                document.body.style.overflow = '';
            }
            modalClose.addEventListener('click', closeHelpModal);
            helpModal.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeHelpModal(); });

            helpForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const name = document.getElementById('nomineeName').value.trim();
                if (!name) { alert('Please fill in all required fields.'); return; }
                alert(`✅ ${name} has been nominated for the "Help a Fellow Human" program.`);
                helpForm.reset();
                closeHelpModal();
            });

            // ---------- DARK MODE ----------
            document.getElementById('darkModeToggle').addEventListener('click', () => {
                document.body.classList.toggle('dark');
            });

            document.getElementById('langSelect').addEventListener('change', (e) => {
                alert(`🌍 Language: ${e.target.value.toUpperCase()}`);
            });

            document.getElementById('countrySelect').addEventListener('change', (e) => {
                alert(`📍 Region set to ${e.target.options[e.target.selectedIndex].text}`);
            });

            // ---------- OFFLINE ----------
            const offlineBadge = document.getElementById('offlineBadge');

            function updateOnlineStatus() {
                if (navigator.onLine) {
                    offlineBadge.classList.remove('show');
                } else {
                    offlineBadge.classList.add('show');
                }
            }
            window.addEventListener('online', updateOnlineStatus);
            window.addEventListener('offline', updateOnlineStatus);
            updateOnlineStatus();

            // ---------- INITIALIZE ----------
            renderStudents();
            renderProgressTable();
            renderAssessments();

            console.log('SkillBridge · Newsletter, Search, Help Chat, Calendar added');
        })();
    </script>
</body>
</html>
