                }
                if (lower.includes('enrol')) {
                    return '🎓 Enrol for $15! Access all 10 modules, AI tutor, placement board, certificate, and Business Blueprint.';
                }
                return "I know all 213 courses with IDs SB.001 to SB.213. Use the search bar for 'SB.151' (Butchery), 'SB.154' (Bakery), 'SB.158' (Street Food), 'SB.161' (Goat Farming), or 'SB.126' (Animal Fattening)!";
            }

            qaSubmit.addEventListener('click', function() {
                const q = qaInput.value.trim();
                if (!q) { qaResponse.textContent = 'Please type a question.'; return; }
                qaResponse.textContent = 'Thinking...';
                setTimeout(() => { qaResponse.textContent = answerQ(q); }, 300);
            });
            qaInput.addEventListener('keypress', function(e) { if (e.key === 'Enter') qaSubmit.click(); });

            // ---------- DARK MODE ----------
            document.getElementById('darkModeToggle').addEventListener('click', () => {
                document.body.classList.toggle('dark');
            });

            // ---------- NEWSLETTER ----------
            document.getElementById('newsletterBtn').addEventListener('click', function() {
                const email = document.getElementById('newsletterEmail').value.trim();
                if (!email || !email.includes('@')) { alert('Please enter a valid email.'); return; }
                alert(`✅ Subscribed: ${email}`);
                document.getElementById('newsletterEmail').value = '';
            });

            // ---------- OFFLINE ----------
            const offlineBadge = document.getElementById('offlineBadge');

            function updateOnlineStatus() {
                if (navigator.onLine) {
                    offlineBadge.classList.remove('show');
                } else {
                    offlineBadge.classList.add('show');
                }
            }
            window.addEventListener('online', updateOnlineStatus);
            window.addEventListener('offline', updateOnlineStatus);
            updateOnlineStatus();

            // ---------- INIT ----------
            renderCountryMap();
            renderStudents();
            renderProgressTable();
            renderAssessments();

            console.log('✅ All 213 courses with unique IDs (SB.001 to SB.213)');
            console.log('✅ Course IDs: Butchery=SB.151, Bakery=SB.154, Street Food=SB.158, Goat=SB.161, Animal Fattening=SB.126');
            console.log('✅ QR Code check functionality working');
            console.log('✅ All sidebar links working');
        })();
    </script>
</body>
</html>
