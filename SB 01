                    { title: 'Capstone Planning', icon: '🎯' },
                    { title: 'Final Review & Assessment', icon: '✅' }
                ];

                return baseModules.map((module, index) => {
                    const moduleNum = index + 1;
                    const weeks = `${index*2+1}-${index*2+2}`;
