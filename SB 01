            // ---------- DOWNLOAD BLUEPRINT ----------
            function downloadBlueprint(courseName) {
                const blueprint = getBlueprint(courseName);
                const content = `
                    🚀 ${blueprint.title}
                    ========================
                    
                    ${blueprint.description}
                    
                    💰 STARTUP COSTS: ${blueprint.startupCost}
                    📊 MONTHLY REVENUE: ${blueprint.monthlyRevenue}
                    📈 PROFIT MARGIN: ${blueprint.profitMargin}
                    ⏱️ BREAK-EVEN: ${blueprint.breakEven}
                    
                    EQUIPMENT NEEDED:
                    ${blueprint.equipment.map(e => `  • ${e.item}: ${e.cost}`).join('\n')}
                    
                    MONTHLY COSTS:
                    ${blueprint.monthlyCosts.map(c => `  • ${c.item}: ${c.cost}`).join('\n')}
                    
                    PRICING GUIDE:
                    ${blueprint.pricing.map(p => `  • ${p.item}: ${p.price}`).join('\n')}
                    
                    STEP-BY-STEP ACTION PLAN:
                    ${blueprint.steps.map((s, i) => `  ${i+1}. ${s}`).join('\n')}
                    
                    CASHFLOW PROJECTION (6 Months):
                    ${Object.entries(blueprint.cashflow).map(([month, data]) => 
                        `  ${month}     $${data.revenue}     $${data.expenses}     $${data.profit}`
                    ).join('\n')}
                    
                    💡 Pro Tip: Start small and scale gradually.
                    
                    © SkillBridge Africa - Business Launch Blueprint
                    Course: ${courseName}
                    Date: ${new Date().toLocaleDateString()}
                `;
                
                const blob = new Blob([content], { type: 'text/plain' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `${courseName.replace(/[^a-zA-Z0-9]/g, '_')}_Blueprint.txt`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
                alert('📄 Blueprint downloaded!');
            }

